### Step 1 — Login
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "admin",
  "password": "admin"
}

> {%
  client.global.set("token", response.body.token);
  client.global.set("run", String(Date.now()));
%}

###

### Step 2 — Create customer party
POST {{host}}/party
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "personType": "INDIVIDUAL",
  "cpf": "55566677788",
  "legalName": "Cliente Receivable {{run}}",
  "name": "Cliente Rec {{run}}",
  "customer": true,
  "supplier": false,
  "salesperson": false
}

> {%
  client.global.set("customerId", response.body.id);
%}

###

### Step 3a — Create salesperson
POST {{host}}/party
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "personType": "INDIVIDUAL",
  "cpf": "11122233344",
  "legalName": "Vendedor Rec {{run}}",
  "name": "Vendedor Rec {{run}}",
  "customer": false,
  "supplier": false,
  "salesperson": true,
  "commissionPercent": 5.00
}

> {%
  client.global.set("salespersonId", response.body.id);
%}

###

### Step 3b — Create brand
POST {{host}}/catalog/brands
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Brand Rec {{run}}"
}

> {%
  client.global.set("brandId", response.body.id);
%}

###

### Step 3c — Create category
POST {{host}}/catalog/categories
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Cat Rec {{run}}",
  "parentId": null
}

> {%
  client.global.set("categoryId", response.body.id);
%}

###

### Step 3d — Create size
POST {{host}}/catalog/sizes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "M"
}

> {%
  client.global.set("sizeId", response.body.id);
%}

###

### Step 3e — Create product + SKU
POST {{host}}/catalog/products
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Rec Shirt {{run}}",
  "price": 200.00,
  "cost": 100.00,
  "purchaseDate": null,
  "colorId": null,
  "brandId": "{{brandId}}",
  "categoryId": "{{categoryId}}",
  "skus": [
    {
      "barcode": "{{$uuid}}",
      "sizeId": "{{sizeId}}",
      "implantationQty": 50
    }
  ]
}

> {%
  client.global.set("productId", response.body.id);
  client.global.set("skuId", response.body.skus[0].id);
%}

###

### Step 4 — Create sale with INSTALLMENT modality (triggers SaleConfirmedListener in finance)
# 2 units × 200 = 400; split: 200 PIX (immediate) + 200 INSTALLMENT (deferred → creates receivable)
POST {{host}}/sales
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerId": "{{customerId}}",
  "origin": "DIRECT",
  "consignmentId": null,
  "issueDate": "2026-07-01",
  "storeCreditNoteId": null,
  "storeCreditDiscount": null,
  "notes": "Receivable flow test {{run}}",
  "items": [
    {
      "skuId": "{{skuId}}",
      "productId": "{{productId}}",
      "quantity": 2,
      "unitPrice": 200.00
    }
  ],
  "installments": [
    {
      "paymentModality": "PIX",
      "dueDate": "2026-07-01",
      "amount": 200.00
    },
    {
      "paymentModality": "INSTALLMENT",
      "dueDate": "2026-08-01",
      "amount": 200.00
    }
  ],
  "sellers": [
    {
      "salespersonId": "{{salespersonId}}",
      "sharePercent": 100
    }
  ]
}

> {%
  client.global.set("saleId", response.body.id);
%}

###

### Step 5 — GET /receivables?customerId — capture receivable id
# Served from Elasticsearch (synchronous replication)
GET {{host}}/receivables?customerId={{customerId}}&size=20
Authorization: Bearer {{token}}

> {%
  client.global.set("receivableId", response.body.content[0].receivableId);
%}

###

### Step 6 — POST /receivables/{{receivableId}}/payments — partial payment (100 of 200)
POST {{host}}/receivables/{{receivableId}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount": 100.00
}

###

### Step 7 — GET /receivables/{{receivableId}} — assert PARTIALLY_PAID
GET {{host}}/receivables/{{receivableId}}
Authorization: Bearer {{token}}

###

### Step 8 — POST /receivables/{{receivableId}}/payments — final payment (remaining 100)
POST {{host}}/receivables/{{receivableId}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount": 100.00
}

###

### Step 9 — GET /receivables/{{receivableId}} — assert PAID
GET {{host}}/receivables/{{receivableId}}
Authorization: Bearer {{token}}

###

### Step 10 — GET /commissions?salespersonId — verify pendingAmount was reduced after ReceivablePaid
GET {{host}}/commissions?salespersonId={{salespersonId}}&size=20
Authorization: Bearer {{token}}

###

### --- Error cases ---

### Error 1 — Overpayment → 422 Unprocessable Entity
# Create a fresh sale to get a new receivable
POST {{host}}/sales
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerId": "{{customerId}}",
  "origin": "DIRECT",
  "consignmentId": null,
  "issueDate": "2026-07-15",
  "storeCreditNoteId": null,
  "storeCreditDiscount": null,
  "notes": "Overpayment test {{run}}",
  "items": [
    {
      "skuId": "{{skuId}}",
      "productId": "{{productId}}",
      "quantity": 1,
      "unitPrice": 200.00
    }
  ],
  "installments": [
    {
      "paymentModality": "INSTALLMENT",
      "dueDate": "2026-08-15",
      "amount": 200.00
    }
  ],
  "sellers": [
    {
      "salespersonId": "{{salespersonId}}",
      "sharePercent": 100
    }
  ]
}

> {%
  client.global.set("saleId2", response.body.id);
%}

###

### Error 2 — List receivables for second sale
GET {{host}}/receivables?customerId={{customerId}}&size=20
Authorization: Bearer {{token}}

> {%
  client.global.set("receivableId2", response.body.content[0].receivableId);
%}

###

### Error 3 — Overpayment on fresh receivable → 422
POST {{host}}/receivables/{{receivableId2}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount": 9999.00
}

###

### Error 4 — Payment on PAID receivable → 422
# receivableId from step 8/9 is now PAID
POST {{host}}/receivables/{{receivableId}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount": 10.00
}

###
